# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
.env.example
.DS_Store
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Node
node_modules/

# Logs & Secrets
*.log
secrets/

# ==============================================================================
# Terraform
# ==============================================================================
# Core state files and local backups
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files if they contain secrets (highly recommended)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore the local .terraform directory (where providers and modules are cached)
.terraform/
